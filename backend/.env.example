# FastAPI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./agrisense.db
SQL_ECHO=false

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BACKOFF_SECONDS=1.5
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_REASONING_EFFORT=high
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=AgriSense AI
OPENROUTER_RATE_LIMIT_RPM=10

# OpenRouter Vision
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_TIMEOUT_SECONDS=60
OPENROUTER_VISION_MAX_RETRIES=3
OPENROUTER_VISION_RETRY_BACKOFF_SECONDS=1.5
OPENROUTER_VISION_MAX_IMAGE_SIDE=1024
OPENROUTER_VISION_IMAGE_JPEG_QUALITY=82
OPENROUTER_VISION_MAX_UPLOAD_BYTES=8388608

# RAG
FAISS_INDEX_PATH=./data/faiss_index
DOCUMENTS_PATH=./data/documents
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Server
API_HOST=0.0.0.0
API_PORT=8000